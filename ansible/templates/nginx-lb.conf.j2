# Nginx — Reverse Proxy vers le Control Plane API
# Généré par Ansible — ne pas modifier manuellement

upstream control_plane {
    server {{ private_cp_ip }}:8000;
    keepalive 32;
}

server {
    listen 80;
    server_name {{ domain }};

    # Santé du LB
    location /health {
        access_log off;
        return 200 "ok\n";
        add_header Content-Type text/plain;
    }

    # Redirige tout le trafic HTTP vers HTTPS (activer après Certbot)
    # return 301 https://$host$request_uri;

    location / {
        proxy_pass         http://control_plane;
        proxy_http_version 1.1;

        # Headers forwarded
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # WebSocket support (proxy pool extension)
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection "upgrade";

        # Timeouts
        proxy_connect_timeout 10s;
        proxy_send_timeout    60s;
        proxy_read_timeout    60s;
    }
}
