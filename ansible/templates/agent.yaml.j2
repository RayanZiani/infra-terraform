# Config Go Agent — généré par Ansible
api:
  base_url: "http://{{ private_cp_ip }}:8000"
  api_key: "{{ agent_api_key }}"
  heartbeat_interval: 30s
  retry_max: 5
  retry_backoff: 2s

wireguard:
  interface: wg0
  port: {{ wireguard_port }}
  ip_pool: "10.8.0.0/16"
  mtu: 1420

logging:
  level: info
  encrypt: false

kill_switch:
  enabled: true
  timeout: 5m
